# Copy this file to .env for live Make CLI runs.
# Fixture mode works without these values.

MAKE_API_KEY=
MAKE_ZONE=eu1.make.com

# Optional: override the CLI binary. Defaults to `make-cli`, then falls back to `npx --yes @makehq/cli`.
# MAKE_CLI_BIN=make-cli

# Pre-approved scenario IDs for the four demo workflows.
MAKE_LEAD_QUALIFICATION_SCENARIO_ID=
MAKE_CUSTOMER_ESCALATION_SCENARIO_ID=
MAKE_DEAL_DESK_SCENARIO_ID=
MAKE_INVOICE_EXCEPTION_SCENARIO_ID=
